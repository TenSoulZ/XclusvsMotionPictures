# Xclusvs Motion Pictures - Environment Configuration Template

# === Backend (Django) ===
# Generate a secret key: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (Default is SQLite, but for production consider PostgreSQL)
# DATABASE_URL=postgres://user:password@localhost:5432/xmp_db

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=webmaster@localhost
NOTIFICATION_EMAIL=xclusvsmotionpictures@gmail.com

# CORS Settings (Frontend URL)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173


# === Frontend (React/Vite) ===
# Note: Variables must be prefixed with VITE_ to be exposed to the frontend
VITE_API_URL=http://localhost:8000/api

# Social Media Links
VITE_INSTAGRAM_URL=https://www.instagram.com/xclusvsmotionpictures
VITE_YOUTUBE_URL=https://www.youtube.com/@xclusvsmotionpictures
VITE_FACEBOOK_URL=https://www.facebook.com/xclusvsmotionpictures
